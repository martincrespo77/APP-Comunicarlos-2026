# ─────────────────────────────────────────────────────────────────────────────
#  .env.example — Mesa de Ayuda Comunicarlos
#
#  Instrucciones:
#    1. Copiar este archivo: cp .env.example .env
#    2. Reemplazar los valores marcados con <CAMBIAR>
#    3. NUNCA commitear el .env real al repositorio
#
#  Este archivo .env.example SÍ se commitea: documenta qué variables
#  necesita la aplicación sin exponer valores reales.
# ─────────────────────────────────────────────────────────────────────────────


# ── Autenticación JWT ────────────────────────────────────────────────────────

# Clave secreta para firmar los tokens JWT.
# OBLIGATORIA en producción. Mínimo 32 caracteres aleatorios.
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<CAMBIAR-por-clave-aleatoria-de-al-menos-32-caracteres>

# Algoritmo de firma JWT. HS256 es el default; no cambiar salvo necesidad.
ALGORITHM=HS256

# Tiempo de vida del token en minutos. Default: 60.
EXPIRACION_MINUTOS=60


# ── Base de datos ────────────────────────────────────────────────────────────

# SQLite en volumen Docker (default para el TP / demo):
DATABASE_URL=sqlite:////data/mesa_de_ayuda.db

# Para desarrollo local (sin Docker), usar ruta relativa:
# DATABASE_URL=sqlite:///./mesa_de_ayuda.db

# Para PostgreSQL (producción real):
# DATABASE_URL=postgresql://usuario:password@host:5432/mesa_de_ayuda
