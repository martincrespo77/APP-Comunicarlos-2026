# ── Variables de entorno reales ───────────────────────────────────────────────
# NUNCA commitear el .env con credenciales reales.
# Usar .env.example como plantilla.
.env

# ── Entorno virtual local ─────────────────────────────────────────────────────
.venv/

# ── Caché de Python ───────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
dist/
build/

# ── Archivos residuales de bases de datos ──────────────────────────────
# MongoDB no genera archivos locales; esta sección queda por higiene general.
# dump/ se ignora por si se usan mongodump u otras herramientas de backup local.
dump/
*.db
*.sqlite

# ── Pytest ────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── Sistema operativo ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
